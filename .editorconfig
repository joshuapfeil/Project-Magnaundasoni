# EditorConfig — Project Magnaundasoni
# https://editorconfig.org

root = true

# ── Defaults ──────────────────────────────────────────────────────────────────
[*]
charset                  = utf-8
end_of_line              = lf
indent_style             = space
indent_size              = 4
tab_width                = 4
trim_trailing_whitespace = true
insert_final_newline     = true

# ── C / C++ ───────────────────────────────────────────────────────────────────
[*.{c,cpp,cc,cxx,h,hpp,hxx,inl}]
indent_style = space
indent_size  = 4
max_line_length = 100

# ── C# (Unity plugin) ─────────────────────────────────────────────────────────
[*.cs]
indent_style = space
indent_size  = 4
max_line_length = 120

# ── CMake ─────────────────────────────────────────────────────────────────────
[CMakeLists.txt]
indent_style = space
indent_size  = 4

[*.cmake]
indent_style = space
indent_size  = 4

# ── Markdown ──────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
indent_size              = 2

# ── JSON / package manifests ──────────────────────────────────────────────────
[*.json]
indent_style = space
indent_size  = 2

# ── YAML ──────────────────────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_style = space
indent_size  = 2

# ── Shell scripts ─────────────────────────────────────────────────────────────
[*.sh]
end_of_line = lf

# ── Windows batch / PowerShell ────────────────────────────────────────────────
[*.{bat,cmd,ps1}]
end_of_line = crlf

# ── Python ────────────────────────────────────────────────────────────────────
[*.py]
indent_style = space
indent_size  = 4
max_line_length = 100
